<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">
  <category name="Labels" colour="#5ba58c">
    <block type="label">
      <field name="LABEL">label</field>
    </block>
    <block type="comment">
      <field name="COMMENT">comment</field>
    </block>
  </category>
  <category name="Operators" colour="#745ba5">
    <block type="set"></block>
    <block type="beg">
      <field name="NAME">name</field>
    </block>
    <block type="cyc">
      <field name="COUNT">1</field>
    </block>
    <block type="sto"></block>
    <block type="cha"></block>
    <block type="dch"></block>
    <block type="pau"></block>
  </category>
  <category name="Limits" colour="#5b67a5">
    <block type="limit"></block>
    <block type="limit_action"></block>
    <block type="compare">
      <field name="OPERATOR">LT</field>
    </block>
    <block type="and"></block>
    <block type="time">
      <field name="VALUE">0</field>
      <field name="UNIT">SECONDS</field>
    </block>
  </category>
  <category name="Actions" colour="#a55b80">
    <block type="goto">
      <field name="LABEL">label</field>
    </block>
    <block type="err">
      <field name="ERRNUM">1</field>
    </block>
  </category>
  <category name="Registration" colour="#5b67a5">
    <block type="registration">
      <field name="REGISTRATION">default</field>
    </block>
  </category>
  <category name="Math" colour="#5b67a5">
    <block type="math_number">
      <field name="NUM">0</field>
    </block>
    <block type="factor"></block>
  </category>
  <category name="Channels" colour="#5ba55b"></category>
  <category name="Variables" colour="#9fa55b">
    <block type="assignment">
      <field name="RHS">0</field>
    </block>
  </category>
</xml>