<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">
  <category name="Statements" colour="#5b80a5">
    <block type="assignment"></block>
    <block type="setvalue"></block>
    <block type="function_charge">
      <statement name="ARGS">
        <block type="assignment">
          <next>
            <block type="limit">
              <value name="CONDITION">
                <block type="comparison">
                  <field name="OPERATOR">&lt;</field>
                </block>
              </value>
            </block>
          </next>
        </block>
      </statement>
    </block>
    <block type="function_discharge">
      <statement name="ARGS">
        <block type="assignment">
          <next>
            <block type="limit">
              <value name="CONDITION">
                <block type="comparison">
                  <field name="OPERATOR">&lt;</field>
                </block>
              </value>
            </block>
          </next>
        </block>
      </statement>
    </block>
    <block type="function_cycle">
      <field name="COUNT">5</field>
    </block>
    <block type="function_pause">
      <statement name="ARGS">
        <block type="limit">
          <value name="CONDITION">
            <block type="time">
              <field name="VALUE">0</field>
              <field name="UNIT">sec</field>
            </block>
          </value>
        </block>
      </statement>
    </block>
    <block type="function">
      <field name="NAME">function</field>
    </block>
  </category>
  <category name="Limits" colour="#5ba55b">
    <block type="limit"></block>
    <block type="limit_action"></block>
    <block type="comparison">
      <field name="OPERATOR">&lt;</field>
    </block>
    <block type="time">
      <field name="VALUE">0</field>
      <field name="UNIT">sec</field>
    </block>
    <block type="action_error">
      <field name="ERRNUM">0</field>
    </block>
    <block type="action_goto">
      <field name="LABEL">label</field>
    </block>
  </category>
  <category name="Variables" colour="#a55b80"></category>
  <category name="Channels" colour="#995ba5"></category>
  <category name="Registrations">
    <block type="registration"></block>
  </category>
  <category name="Other" colour="#5ba58c">
    <block type="number">
      <field name="NUMBER">0</field>
    </block>
    <block type="comment">
      <field name="TEXT">text</field>
    </block>
    <block type="label">
      <field name="LABEL">text</field>
    </block>
  </category>
</xml>